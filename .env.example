# Required
TELEGRAM_BOT_TOKEN=123456:replace_me

# Optional: global stocks / company news via Finnhub
FINNHUB_API_KEY=

# Optional: comma-separated RSS feeds for market news.
# Examples can be RBK, PRIME, company feeds, or your own parser endpoint.
RSS_FEEDS=

# Optional: separate comma-separated RSS feeds for issuer disclosures / corporate messages.
DISCLOSURE_RSS_FEEDS=

# Storage and local data
SQLITE_PATH=./data/bot.sqlite3
EVENTS_CSV_PATH=./data/events.csv

# Bot defaults
DEFAULT_PERIOD=1m
DEFAULT_MARKET=MOEX
TZ=Europe/Moscow
HTTP_TIMEOUT_SECONDS=15
CACHE_TTL_SECONDS=60

# Background jobs
ALERT_CHECK_INTERVAL_SECONDS=60
DIGEST_CHECK_INTERVAL_SECONDS=60
DIGEST_DEFAULT_TIME=09:30
SCREENER_LIMIT=10
